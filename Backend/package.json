{
  "name": "aio",
  "version": "1.0.50",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "migrate-dev": "bun run migrate dev",
    "migrate": "bun prisma migrate dev --name init && bun prisma generate",
    "migrate:deploy": "bun prisma migrate deploy",
    "db:seed": "bun seed.ts",
    "build": "bun prisma generate && bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/index.ts",
    "start": "./server"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.28",
    "pg": "^8.20.0",
    "prismabox": "^1.1.26",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "bun-types": "^1.3.13",
    "prisma": "^7.7.0"
  },
  "module": "src/index.js"
}
